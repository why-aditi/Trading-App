# Privy (get from privy.io dashboard)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Supabase (get from supabase.com project settings)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# BirdEye (get from birdeye.so/data-api)
BIRDEYE_API_KEY=

# Alchemy Solana Devnet RPC (M2 trading — devnet only, no real funds)
# Create an Alchemy app targeting "Solana Devnet"
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_KEY

# After login, airdrop devnet SOL: solana airdrop 2 <wallet_address> --url devnet
